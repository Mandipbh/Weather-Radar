<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TheWeatherApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="colorPrimaryVariant">@color/primary_dark_blue</item>

        <!-- Status Bar & Navigation Bar Customization (Full Screen / Transparent) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- White status bar icons for dark backgrounds -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Full screen mode -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.TheWeatherApp" parent="Base.Theme.TheWeatherApp" />

    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Custom TextView Style -->
    <style name="CustomTextStyle" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize" tools:ignore="SpUsage">16sp</item>
        <item name="android:fontFamily">@font/roboto_family</item>
        <item name="fontFamily">@font/roboto_family</item>
    </style>

    <!-- Custom TextInput Card Style -->
    <style name="CustomInputCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_blue</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/primary_blue</item>
    </style>


    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipSurfaceColor">#00000000</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="android:textSize" tools:ignore="SpUsage">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="rippleColor">#2000E5FF</item>
        <item name="chipIconVisible">false</item>
        <item name="ensureMinTouchTargetSize">false</item>
        <!-- Elevation shadow for selected -->
        <item name="android:elevation">2dp</item>
    </style>

    <!-- ===== CARD DIVIDER (inside glass cards) ===== -->
    <style name="CardDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#15FFFFFF</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:layout_marginEnd">14dp</item>
    </style>

    <!-- ===== OLD STYLES (keep for compatibility) ===== -->
    <style name="RowStyle">
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="RowLabel">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize" tools:ignore="SpUsage">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="RowChipGroup">
        <!-- kept for old layout compat -->
    </style>

    <style name="MultiChipGroup">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#20FFFFFF</item>
    </style>

    <style name="Widget.App.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <!-- Box background: dark glass -->
        <item name="boxBackgroundColor">#0AFFFFFF</item>

        <!-- Unfocused border: dim white -->
        <item name="boxStrokeColor">@color/textfield_stroke_selector</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>

        <!-- Hint text -->
        <item name="hintTextColor">@color/textfield_hint_selector</item>
        <item name="android:textColorHint">#50FFFFFF</item>

        <!-- Counter text (0/80) -->
        <item name="counterTextColor">@color/counter_text</item>
        <item name="counterOverflowTextColor">@color/counter_overflow</item>

        <!-- Error -->
        <item name="errorTextColor">@color/counter_overflow</item>
        <item name="errorIconDrawable">@null</item>
    </style>
</resources>
