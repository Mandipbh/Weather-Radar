<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TheWeatherApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="colorPrimaryVariant">@color/primary_dark_blue</item>
    </style>

    <style name="Theme.TheWeatherApp" parent="Base.Theme.TheWeatherApp" />

    <!-- Custom TextView Style -->
    <style name="CustomTextStyle" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Custom TextInput Card Style -->
    <style name="CustomInputCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_blue</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/primary_blue</item>
    </style>


    <style name="Widget.App.Chip" parent="Widget.Material3.Chip.Filter">

        <!-- Size -->
        <item name="chipMinHeight">36dp</item>
        <item name="chipMinTouchTargetSize">36dp</item>

        <!-- Background -->
        <item name="chipBackgroundColor">@color/black</item>

        <!-- Border -->
        <item name="chipStrokeWidth">2dp</item>
        <item name="chipStrokeColor">@color/accent</item>

        <!-- Text -->
        <item name="android:textColor">@color/chip_text_selector</item>

        <!-- Shape -->
        <item name="shapeAppearance">@style/ShapeAppearance.App.Chip</item>

        <!-- Behavior -->
        <item name="checkedIconVisible">false</item>

    </style>

    <style name="ShapeAppearance.App.Chip" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="RowStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <style name="RowLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RowChipGroup">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="singleSelection">true</item>
        <item name="selectionRequired">true</item>
        <item name="chipSpacingHorizontal">8dp</item>
    </style>

    <style name="MultiChipGroup">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="singleSelection">true</item>
        <item name="chipSpacing">8dp</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@drawable/divider</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>
</resources>
