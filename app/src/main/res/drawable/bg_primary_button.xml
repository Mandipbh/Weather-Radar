<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <layer-list>
            <!-- Shadow Layer -->
            <item
                android:bottom="0dp"
                android:left="2dp"
                android:right="2dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#33000000" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <!-- Main Button Layer -->
            <item
                android:bottom="4dp"
                android:left="0dp"
                android:right="0dp"
                android:top="0dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="0"
                        android:endColor="#00E5FF"
                        android:startColor="#00B8D4"
                        android:type="linear" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>