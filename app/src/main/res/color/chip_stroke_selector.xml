<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected: full cyan border -->
    <item android:state_checked="true" android:color="#00E5FF" />
    <!-- Pressed -->
    <item android:state_pressed="true" android:color="#80E5FF" />
    <!-- Default: 30% white border -->
    <item android:color="#4DFFFFFF" />
</selector>