<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_unit_settings"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Location"
        android:textColor="#B3FFFFFF"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/iv_refresh"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_refresh"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_location"
        android:text="25°"
        android:textColor="@color/white"
        android:textSize="48sp" />

    <TextView
        android:id="@+id/tv_time_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/tv_temp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:layout_toEndOf="@id/tv_temp"
        android:text="Time Date"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_condition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_time_date"
        android:layout_toEndOf="@id/tv_temp"
        android:layout_marginStart="12dp"
        android:text="Condition"
        android:textColor="#B3FFFFFF"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/ll_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_temp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_uv_humidity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="UV/Hum"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_min_max_precip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="Min/Max"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/ll_details"
        android:layout_marginTop="8dp"
        android:background="#4DFFFFFF" />

    <LinearLayout
        android:id="@+id/ll_forecast_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/item_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_mini_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="Now"/>
            <ImageView android:id="@+id/iv_mini_icon_1" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cloudy"/>
            <TextView android:id="@+id/tv_mini_temp_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="--°"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_mini_time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="12:00"/>
            <ImageView android:id="@+id/iv_mini_icon_2" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cloudy"/>
            <TextView android:id="@+id/tv_mini_temp_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="--°"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_mini_time_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="13:00"/>
            <ImageView android:id="@+id/iv_mini_icon_3" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cloudy"/>
            <TextView android:id="@+id/tv_mini_temp_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="--°"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_mini_time_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="14:00"/>
            <ImageView android:id="@+id/iv_mini_icon_4" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cloudy"/>
            <TextView android:id="@+id/tv_mini_temp_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="--°"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_mini_time_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="15:00"/>
            <ImageView android:id="@+id/iv_mini_icon_5" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cloudy"/>
            <TextView android:id="@+id/tv_mini_temp_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="--°"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_mini_time_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="16:00"/>
            <ImageView android:id="@+id/iv_mini_icon_6" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cloudy"/>
            <TextView android:id="@+id/tv_mini_temp_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="10sp" android:text="--°"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
