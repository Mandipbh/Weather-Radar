<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weather_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:orientation="vertical">

        <!-- Weather Main Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_weather_gradient"
            android:padding="20dp"
            android:paddingBottom="30dp">

            <!-- Location Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="40dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Lot 478, Block B2 Block B 2 Phase 1\nJohar Town, Lahore, 54600, Pakistan"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/white" />
            </LinearLayout>

            <!-- Favorite + Action Icons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_star_filled"
                    app:tint="@color/accent_orange" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Right side icons -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_location_pin"
                        app:tint="@color/white"
                        android:layout_marginBottom="8dp" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_grid"
                        app:tint="@color/white"
                        android:layout_marginBottom="8dp" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_alert"
                        android:layout_marginBottom="8dp" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_beer" />
                </LinearLayout>
            </LinearLayout>

            <!-- Weather Condition -->
            <TextView
                android:id="@+id/tv_condition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overcast Clouds"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <!-- Temperature -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="17"
                    android:textColor="@color/white"
                    android:textSize="96sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="0.85" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="°C"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_gravity="top"
                    android:layout_marginTop="20dp" />
            </LinearLayout>

            <!-- Weather Icon -->
            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_cloudy"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Min/Max Temp + Rain -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_min_max"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14°C / 22°C"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:layout_marginEnd="16dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_rain"
                    app:tint="@color/light_blue"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_rain_chance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Real Feel -->
            <TextView
                android:id="@+id/tv_real_feel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Real Feel 16°C"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Sunrise / Sunset Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_sunrise"
                        app:tint="@color/white" />

                    <!-- Arc progress bar (use a custom view or ProgressBar) -->
                    <ProgressBar
                        android:id="@+id/pb_sun"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:progress="15"
                        android:progressTint="@color/accent_orange"
                        android:progressBackgroundTint="@color/white_30" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_sunset"
                        app:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6:08am"
                        android:textColor="@color/white_70"
                        android:textSize="12sp" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_current_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2:07am Thu, 19 March 2026"
                        android:textColor="@color/white_70"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6:12pm"
                        android:textColor="@color/white_70"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Warning Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/weather_bg_dark"
            android:padding="16dp">

            <!-- Warning Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Warning"
                    android:textColor="@color/accent_orange"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Warning Icon Buttons -->
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_uv_warning"
                    android:background="@drawable/bg_icon_button"
                    android:layout_marginStart="6dp" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_air_quality"
                    android:background="@drawable/bg_icon_button"
                    android:layout_marginStart="6dp" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_radar_circle"
                    android:background="@drawable/bg_icon_button_selected"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Radar Warning Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_warning_banner"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_radar_circle"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Check your radar location now!"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginStart="10dp" />

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/white" />
            </LinearLayout>

        </LinearLayout>

        <!-- Hourly Forecast Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/weather_bg_dark">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hourly Forecast"
                android:textColor="@color/accent_orange"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Hourly RecyclerView - add this in code -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_hourly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>